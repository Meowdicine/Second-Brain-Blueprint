# Google OAuth (required only if you want Google Tasks integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# Task list names used for dashboard goal mapping
GOOGLE_TASKLIST_WORK_NAME=Work
GOOGLE_TASKLIST_LEARNING_NAME=Learning
GOOGLE_TASKLIST_OPERATIONS_NAME=Operations
GOOGLE_TASKLIST_GENERAL_NAME=General

# Optional single-list mode for phone widget parity.
# When true, all goals are stored in one list and goal metadata is encoded per task.
GOOGLE_TASKS_SINGLE_LIST_MODE=true
GOOGLE_TASKLIST_PRIMARY_NAME=General

# Optional token storage override. Default:
# %LOCALAPPDATA%/CursorMemo/secrets/google-tasks-token.json
GOOGLE_TOKEN_STORE_PATH=

# External launch bridge. Defaults to true in development, false in production.
EXTERNAL_OPEN_ENABLED=true
